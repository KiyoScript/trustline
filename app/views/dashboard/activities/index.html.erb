<%# app/views/dashboard/activities/index.html.erb %>

<%
  type_meta = {
    "call"             => { icon: "phone",                     color: "text-blue-500",   bg: "bg-blue-50",   border: "border-blue-200" },
    "email"            => { icon: "envelope",                  color: "text-indigo-500", bg: "bg-indigo-50", border: "border-indigo-200" },
    "linkedin_message" => { icon: "chat-bubble-left-ellipsis", color: "text-teal-500",   bg: "bg-teal-50",   border: "border-teal-200" },
    "meeting"          => { icon: "user-group",                color: "text-purple-500", bg: "bg-purple-50", border: "border-purple-200" },
    "note"             => { icon: "document",                  color: "text-gray-500",   bg: "bg-gray-50",   border: "border-gray-200" },
    "proposal_sent"    => { icon: "document-text",             color: "text-amber-500",  bg: "bg-amber-50",  border: "border-amber-200" },
    "follow_up"        => { icon: "calendar",                  color: "text-teal-500",   bg: "bg-teal-50",   border: "border-teal-200" },
  }

  tab_labels = {
    "call"             => "Call",
    "email"            => "Email",
    "linkedin_message" => "LinkedIn",
    "meeting"          => "Meeting",
    "note"             => "Note",
    "proposal_sent"    => "Proposal",
    "follow_up"        => "Follow-up",
  }

  active_meta = type_meta[@active_tab]
%>

<div class="p-6 bg-base-200 min-h-screen">

  <%# Header %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-base-content">Activity Center</h1>
      <p class="text-sm text-base-content/50 mt-0.5">Log and track all sales activities</p>
    </div>
    <button
      onclick="document.getElementById('log_activity_modal').showModal()"
      class="btn btn-primary btn-sm gap-2">
      <%= icon "plus", library: "heroicons", class: "size-4" %>
      Log Activity
    </button>
  </div>

  <%# This Week / This Month Totals %>
  <div class="grid grid-cols-2 gap-3 mb-5">
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 flex-row items-center justify-between">
        <div>
          <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">This week</p>
          <p class="text-2xl font-bold text-base-content mt-1"><%= @this_week_count %></p>
        </div>
        <%= icon "calendar-days", library: "heroicons", class: "size-8 text-primary/30" %>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 flex-row items-center justify-between">
        <div>
          <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">This month</p>
          <p class="text-2xl font-bold text-base-content mt-1"><%= @this_month_count %></p>
        </div>
        <%= icon "chart-bar", library: "heroicons", class: "size-8 text-success/30" %>
      </div>
    </div>
  </div>

  <%# Tab Bar — server-side navigation, no tab-content %>
  <div class="grid grid-cols-7 gap-2 mb-5">
    <% tab_labels.each do |type, label| %>
      <% meta  = type_meta[type] %>
      <% count = @counts[type] || 0 %>
      <% is_active = type == @active_tab %>
      <%= link_to dashboard_activities_path(tab: type),
            class: "card border cursor-pointer transition-all py-4 px-3 text-center #{is_active ? 'border-primary bg-primary/5' : 'border-base-300 bg-base-100 hover:bg-base-200'}" do %>
        <div class="flex flex-col items-center gap-1.5">
          <%= icon meta[:icon], library: "heroicons", class: "size-5 #{is_active ? meta[:color] : 'text-base-content/30'}" %>
          <span class="text-2xl font-bold <%= is_active ? 'text-base-content' : 'text-base-content/50' %> leading-none"><%= count %></span>
          <span class="text-xs <%= is_active ? 'text-base-content/70' : 'text-base-content/40' %>"><%= label %></span>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Search bar %>
  <%= search_form_for @query, url: dashboard_activities_path(tab: @active_tab), method: :get, html: { class: "mb-4" } do |f| %>
    <div class="flex items-center gap-3">
      <label class="input input-bordered input-sm flex items-center gap-2 flex-1 max-w-lg bg-base-100">
        <%= icon "magnifying-glass", library: "heroicons", class: "size-4 text-base-content/40 shrink-0" %>
        <%= f.search_field :lead_company_name_or_notes_or_result_cont,
              placeholder: "Search by company, notes...",
              class: "grow bg-transparent outline-none text-sm" %>
      </label>
      <%= f.submit "Search", class: "btn btn-outline btn-sm" %>
      <%= link_to "Clear", dashboard_activities_path(tab: @active_tab), class: "btn btn-ghost btn-sm" %>
    </div>
  <% end %>

  <%# Activity Feed %>
  <% if @activities.empty? %>
    <div class="card bg-base-100 border border-base-200">
      <div class="flex flex-col items-center justify-center text-center py-16">
        <div class="bg-base-200 rounded-full p-5 size-20 flex items-center justify-center mb-4">
          <%= icon active_meta[:icon], library: "heroicons", class: "size-9 text-base-content/25" %>
        </div>
        <p class="font-bold text-base">No <%= tab_labels[@active_tab] %> activities yet</p>
        <p class="text-base-content/40 text-sm font-normal mt-1">Log one using the button above</p>
      </div>
    </div>
  <% else %>
    <div class="card bg-base-100 border border-base-300/50 rounded-2xl shadow-sm">
      <div class="divide-y divide-base-200">
        <% @activities.each do |activity| %>
          <div class="flex items-start gap-4 p-4 hover:bg-base-200/40 transition-colors">

            <%# Type icon %>
            <div class="shrink-0 mt-0.5">
              <div class="size-9 rounded-full <%= active_meta[:bg] %> border <%= active_meta[:border] %> flex items-center justify-center">
                <%= icon active_meta[:icon], library: "heroicons", class: "size-4 #{active_meta[:color]}" %>
              </div>
            </div>

            <%# Content %>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-base-content">
                <span class="<%= active_meta[:color] %>"><%= activity.type_label %></span>
                —
                <%= link_to activity.lead.company_name,
                      dashboard_lead_path(activity.lead),
                      class: "font-bold hover:text-primary transition-colors" %>
                <span class="text-base-content/50 font-normal">(<%= activity.lead.contact_name %>)</span>
              </p>
              <% if activity.notes.present? %>
                <p class="text-sm text-base-content/60 mt-1"><%= activity.notes %></p>
              <% end %>
              <% if activity.result.present? %>
                <p class="text-sm font-medium text-base-content mt-1">Result: <%= activity.result %></p>
              <% end %>
              <% if activity.next_step.present? %>
                <p class="text-sm text-primary mt-0.5">
                  Next: <%= activity.next_step %>
                  <% if activity.next_step_date.present? %>
                    · <%= activity.next_step_date.strftime("%Y-%m-%d") %>
                  <% end %>
                </p>
              <% end %>
              <p class="text-xs text-base-content/40 mt-1">by <%= activity.user.display_name %></p>
            </div>

            <%# Date + Actions %>
            <div class="flex items-center gap-1 shrink-0">
              <span class="text-sm text-base-content/40 whitespace-nowrap mr-2">
                <%= activity.activity_date.strftime("%Y-%m-%d") %>
              </span>
              <%= link_to dashboard_activity_path(activity),
                    class: "btn btn-ghost btn-xs btn-square tooltip",
                    data: { tip: "View" } do %>
                <%= icon "eye", library: "heroicons", class: "size-4" %>
              <% end %>
              <%= link_to edit_dashboard_activity_path(activity),
                    class: "btn btn-ghost btn-xs btn-square tooltip",
                    data: { tip: "Edit" } do %>
                <%= icon "pencil-square", library: "heroicons", class: "size-4" %>
              <% end %>
              <button
                type="button"
                class="btn btn-ghost btn-xs btn-square tooltip text-error"
                data-tip="Delete"
                onclick="document.getElementById('delete_modal_<%= activity.id %>').showModal()">
                <%= icon "trash", library: "heroicons", class: "size-4" %>
              </button>
            </div>

            <%# Per-row delete modal %>
            <dialog id="delete_modal_<%= activity.id %>" class="modal">
              <div class="modal-box max-w-sm">
                <div class="flex flex-col items-center text-center gap-3 mb-5">
                  <div class="size-12 rounded-full bg-error/10 flex items-center justify-center">
                    <%= icon "exclamation-triangle", library: "heroicons", class: "size-6 text-error" %>
                  </div>
                  <div>
                    <h3 class="text-lg font-bold">Delete this activity?</h3>
                    <p class="text-sm text-base-content/50 mt-1">
                      <%= activity.type_label %> — <%= activity.lead.company_name %>
                    </p>
                  </div>
                </div>
                <div class="flex gap-3">
                  <button onclick="document.getElementById('delete_modal_<%= activity.id %>').close()" class="btn btn-ghost btn-sm flex-1">Cancel</button>
                  <%= button_to dashboard_activity_path(activity), method: :delete,
                        class: "btn btn-error btn-sm flex-1" do %>
                    Yes, Delete
                  <% end %>
                </div>
              </div>
              <form method="dialog" class="modal-backdrop"><button>close</button></form>
            </dialog>

          </div>
        <% end %>
      </div>

      <%# Pagy pagination inside card %>
      <% if @pagy.pages > 1 %>
        <div class="flex items-center justify-between px-5 py-3 border-t border-base-300/30 bg-base-100">
          <p class="text-xs text-base-content/40">
            Showing
            <span class="font-semibold text-base-content/70"><%= (@pagy.page - 1) * @pagy.limit + 1 %>–<%= [@pagy.page * @pagy.limit, @pagy.count].min %></span>
            of
            <span class="font-semibold text-base-content/70"><%= @pagy.count %></span>
            activities
          </p>
          <div class="join">
            <% if @pagy.page > 1 %>
              <%= link_to dashboard_activities_path(tab: @active_tab, page: @pagy.page - 1),
                    class: "join-item btn btn-sm btn-ghost" do %>
                <%= icon "chevron-left", library: "heroicons", class: "size-4" %>
              <% end %>
            <% else %>
              <button class="join-item btn btn-sm btn-ghost opacity-30" disabled>
                <%= icon "chevron-left", library: "heroicons", class: "size-4" %>
              </button>
            <% end %>

            <% visible = (1..@pagy.pages).select { |p| p == 1 || p == @pagy.pages || (p - @pagy.page).abs <= 1 } %>
            <% visible.each_with_index do |p, i| %>
              <% if i > 0 && p - visible[i - 1] > 1 %>
                <button class="join-item btn btn-sm btn-disabled" disabled>…</button>
              <% end %>
              <%= link_to p, dashboard_activities_path(tab: @active_tab, page: p),
                    class: "join-item btn btn-sm #{p == @pagy.page ? 'btn-primary' : 'btn-ghost'}" %>
            <% end %>

            <% if @pagy.page < @pagy.pages %>
              <%= link_to dashboard_activities_path(tab: @active_tab, page: @pagy.page + 1),
                    class: "join-item btn btn-sm btn-ghost" do %>
                <%= icon "chevron-right", library: "heroicons", class: "size-4" %>
              <% end %>
            <% else %>
              <button class="join-item btn btn-sm btn-ghost opacity-30" disabled>
                <%= icon "chevron-right", library: "heroicons", class: "size-4" %>
              </button>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

</div>

<%# Log Activity Modal %>
<dialog id="log_activity_modal" class="modal">
  <div class="modal-box w-11/12 max-w-lg">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-lg font-bold">Log Activity</h3>
      <button onclick="document.getElementById('log_activity_modal').close()" class="btn btn-ghost btn-sm btn-circle">
        <%= icon "x-mark", library: "heroicons", class: "size-5" %>
      </button>
    </div>

    <%= form_with url: dashboard_activities_path, method: :post, class: "space-y-4" do |f| %>

      <div class="form-control">
        <%= f.label :lead_id, "Lead *", class: "label label-text text-sm" %>
        <%= f.select :lead_id,
              Lead.active_leads.order(:company_name).map { |l| ["#{l.company_name} — #{l.contact_name}", l.id] },
              { prompt: "Select lead..." },
              class: "select select-bordered w-full", required: true %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="form-control">
          <%= f.label :activity_type, "Activity Type", class: "label label-text text-sm" %>
          <%= f.select :activity_type,
                Activity.activity_types.keys.map { |t| [t.humanize.gsub("_", " "), t] },
                {},
                class: "select select-bordered w-full" %>
        </div>
        <div class="form-control">
          <%= f.label :activity_date, "Date", class: "label label-text text-sm" %>
          <%= f.date_field :activity_date, value: Date.today, class: "input input-bordered w-full" %>
        </div>
      </div>

      <div class="form-control">
        <%= f.label :result, "Result", class: "label label-text text-sm" %>
        <%= f.text_field :result, placeholder: "e.g. Positive, call scheduled...", class: "input input-bordered w-full" %>
      </div>

      <div class="form-control">
        <%= f.label :notes, "Notes", class: "label label-text text-sm" %>
        <%= f.text_area :notes, rows: 3, class: "textarea textarea-bordered w-full" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="form-control">
          <%= f.label :next_step, "Next Step", class: "label label-text text-sm" %>
          <%= f.text_field :next_step, class: "input input-bordered w-full" %>
        </div>
        <div class="form-control">
          <%= f.label :next_step_date, "Next Step Date", class: "label label-text text-sm" %>
          <%= f.date_field :next_step_date, class: "input input-bordered w-full" %>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="document.getElementById('log_activity_modal').close()" class="btn btn-ghost btn-sm">
          Cancel
        </button>
        <%= f.submit "Log Activity", class: "btn btn-primary btn-sm" %>
      </div>

    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
