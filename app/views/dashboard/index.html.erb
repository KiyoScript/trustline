<%# app/views/dashboard/index.html.erb %>

<div class="p-6 bg-base-200 min-h-screen">

  <%# Header %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-base-content">Executive Dashboard</h1>
      <p class="text-sm text-base-content/50 mt-0.5">
        Week of <%= Date.today.beginning_of_week.strftime("%b %-d") %> — <%= Date.today.end_of_week.strftime("%b %-d, %Y") %>
      </p>
    </div>
  </div>

  <%# KPI Row 1 %>
  <div class="grid grid-cols-5 gap-3 mb-3">
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Active Leads</p>
        <p class="text-3xl font-bold text-primary"><%= @active_leads_count %></p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Added This Week</p>
        <p class="text-3xl font-bold text-success"><%= @added_this_week %></p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Removed This Week</p>
        <p class="text-3xl font-bold text-error"><%= @removed_this_week %></p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Net Growth</p>
        <p class="text-3xl font-bold <%= @net_growth_this_week >= 0 ? 'text-success' : 'text-error' %>">
          <%= @net_growth_this_week >= 0 ? "+#{@net_growth_this_week}" : @net_growth_this_week %>
        </p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Moved Forward</p>
        <p class="text-3xl font-bold text-info"><%= @moved_forward_this_week %></p>
      </div>
    </div>
  </div>

  <%# KPI Row 2 %>
  <div class="grid grid-cols-5 gap-3 mb-5">
    <div class="card bg-warning/10 border border-warning/20">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-warning/70 uppercase tracking-wide font-medium">Overdue Actions</p>
        <p class="text-3xl font-bold text-warning"><%= @overdue_actions_count %></p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Calls This Week</p>
        <p class="text-3xl font-bold text-base-content"><%= @calls_this_week %></p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Proposals This Week</p>
        <p class="text-3xl font-bold text-base-content"><%= @proposals_this_week %></p>
      </div>
    </div>
    <div class="card bg-success/10 border border-success/20">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-success/70 uppercase tracking-wide font-medium">Won This Month</p>
        <p class="text-3xl font-bold text-success"><%= @won_this_month %></p>
      </div>
    </div>
    <div class="card bg-error/10 border border-error/20">
      <div class="card-body p-4 gap-2">
        <p class="text-xs text-error/70 uppercase tracking-wide font-medium">Lost This Month</p>
        <p class="text-3xl font-bold text-error"><%= @lost_this_month %></p>
      </div>
    </div>
  </div>

  <%# Top Producer Banner %>
  <% if @top_producer %>
    <div class="card bg-gradient-to-r from-blue-50 to-teal-50 border border-blue-100 mb-5">
      <div class="card-body p-4 flex-row items-center gap-4">
        <%= icon "trophy", library: "heroicons", class: "size-10 text-primary/40 shrink-0" %>
        <div>
          <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Top Producer This Week</p>
          <p class="text-lg font-bold text-base-content"><%= @top_producer.display_name %></p>
          <p class="text-sm text-base-content/50"><%= @top_producer_count %> movements logged this week</p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Charts Row %>
  <div class="grid grid-cols-2 gap-4 mb-4">

    <%# Pipeline Stage Distribution %>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-5">
        <h2 class="font-medium text-base-content mb-4">Pipeline Stage Distribution</h2>
        <div style="position:relative; width:100%; height:220px;">
          <canvas id="stageChart"></canvas>
        </div>
      </div>
    </div>

    <%# Weekly Added vs Removed %>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-5">
        <h2 class="font-medium text-base-content mb-4">Weekly Lead Movement (Last 8 Weeks)</h2>
        <div style="position:relative; width:100%; height:220px;">
          <canvas id="weeklyChart"></canvas>
        </div>
      </div>
    </div>

  </div>

  <%# Alert Lists Row %>
  <div class="grid grid-cols-3 gap-4">

    <%# Overdue Actions %>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Overdue Next Actions</h2>
          <span class="text-xl font-bold text-warning"><%= @overdue_actions_count %></span>
        </div>
        <% if @overdue_leads.empty? %>
          <p class="text-sm text-base-content/30 text-center py-4">No overdue actions</p>
        <% else %>
          <div class="divide-y divide-base-200">
            <% @overdue_leads.each do |lead| %>
              <div class="flex items-center justify-between py-2.5">
                <%= link_to lead.company_name,
                      dashboard_lead_path(lead),
                      class: "text-sm font-medium text-base-content hover:text-primary transition-colors truncate" %>
                <span class="text-sm text-error shrink-0 ml-2">
                  <%= lead.next_action_date&.strftime("%Y-%m-%d") %>
                </span>
              </div>
            <% end %>
          </div>
          <% if @overdue_actions_count > 5 %>
            <%= link_to "View all #{@overdue_actions_count} →",
                  dashboard_leads_path,
                  class: "text-xs text-primary hover:underline mt-3 block" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# Stagnant 7+ Days %>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Stagnant Leads (7+ Days)</h2>
          <span class="text-xl font-bold text-base-content"><%= @stagnant_7.count %></span>
        </div>
        <% if @stagnant_7.empty? %>
          <p class="text-sm text-base-content/30 text-center py-4">No stagnant leads</p>
        <% else %>
          <div class="divide-y divide-base-200">
            <% @stagnant_7.each do |lead| %>
              <div class="flex items-center justify-between py-2.5">
                <%= link_to lead.company_name,
                      dashboard_lead_path(lead),
                      class: "text-sm font-medium text-base-content hover:text-primary transition-colors truncate" %>
                <span class="text-sm text-base-content/50 shrink-0 ml-2">
                  <%= lead.days_since_last_contact %>d ago
                </span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <%# Stagnant 14+ Days %>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-5">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Stagnant Leads (14+ Days)</h2>
          <span class="text-xl font-bold text-error"><%= @stagnant_14.count %></span>
        </div>
        <% if @stagnant_14.empty? %>
          <p class="text-sm text-base-content/30 text-center py-4">No stagnant leads</p>
        <% else %>
          <div class="divide-y divide-base-200">
            <% @stagnant_14.each do |lead| %>
              <div class="flex items-center justify-between py-2.5">
                <%= link_to lead.company_name,
                      dashboard_lead_path(lead),
                      class: "text-sm font-medium text-base-content hover:text-primary transition-colors truncate" %>
                <span class="text-sm text-error shrink-0 ml-2">
                  <%= lead.days_since_last_contact %>d ago
                </span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

  </div>

</div>

<%# Chart.js %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
  // Stage Distribution Bar Chart
  const stageLabels = <%= raw @stage_distribution.map { |s| s[:stage] }.to_json %>;
  const stageCounts = <%= raw @stage_distribution.map { |s| s[:count] }.to_json %>;
  const stageColors = [
    "#888780","#378ADD","#1D9E75","#639922",
    "#D4537E","#7F77DD","#BA7517","#D85A30",
    "#0F6E56","#A32D2D"
  ];

  new Chart(document.getElementById("stageChart"), {
    type: "bar",
    data: {
      labels: stageLabels,
      datasets: [{
        data: stageCounts,
        backgroundColor: stageColors,
        borderRadius: 4,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { color: "#888780", font: { size: 10 }, maxRotation: 40 } },
        y: { grid: { color: "rgba(136,135,128,0.12)" }, ticks: { color: "#888780", font: { size: 11 }, stepSize: 1 }, beginAtZero: true }
      }
    }
  });

  // Weekly Added vs Removed Line Chart
  const weeklyLabels  = <%= raw @weekly_stats.map { |w| w[:label] }.to_json %>;
  const weeklyAdded   = <%= raw @weekly_stats.map { |w| w[:added] }.to_json %>;
  const weeklyRemoved = <%= raw @weekly_stats.map { |w| w[:removed] }.to_json %>;

  new Chart(document.getElementById("weeklyChart"), {
    type: "bar",
    data: {
      labels: weeklyLabels,
      datasets: [
        {
          label: "Added",
          data: weeklyAdded,
          backgroundColor: "#1D9E75",
          borderRadius: 4,
          borderSkipped: false
        },
        {
          label: "Removed",
          data: weeklyRemoved,
          backgroundColor: "#E24B4A",
          borderRadius: 4,
          borderSkipped: false
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: true,
          position: "top",
          labels: { color: "#888780", font: { size: 11 }, boxWidth: 10, boxHeight: 10 }
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { color: "#888780", font: { size: 11 } } },
        y: { grid: { color: "rgba(136,135,128,0.12)" }, ticks: { color: "#888780", font: { size: 11 }, stepSize: 1 }, beginAtZero: true }
      }
    }
  });
</script>
