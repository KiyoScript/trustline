<%# app/views/dashboard/teams/index.html.erb %>

<%
  role_colors = {
    "super_admin" => { badge: "badge-error",    label: "Super Admin" },
    "admin"       => { badge: "badge-primary",  label: "Admin" },
    "manager"     => { badge: "badge-secondary",label: "Manager" },
    "agent"       => { badge: "badge-success",  label: "Agent" },
    "viewer"      => { badge: "badge-ghost",    label: "Viewer" },
  }

  role_order = { "super_admin" => 0, "admin" => 1, "manager" => 2, "agent" => 3, "viewer" => 4 }
  sorted_members = @members.sort_by { |m| role_order[m[:role]] || 99 }
%>

<div class="p-6 bg-base-200 min-h-screen">

  <%# Header %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-base-content">Team</h1>
      <p class="text-sm text-base-content/50 mt-0.5"><%= @members.size %> members</p>
    </div>
    <button
      onclick="document.getElementById('invite_modal').showModal()"
      class="btn btn-primary btn-sm gap-2">
      <%= icon "user-plus", library: "heroicons", class: "size-4" %>
      Invite Member
    </button>
  </div>

  <%# Summary KPIs %>
  <div class="grid grid-cols-4 gap-3 mb-6">
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-1">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Total Members</p>
        <p class="text-2xl font-bold text-base-content"><%= @members.size %></p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-1">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Admins & Managers</p>
        <p class="text-2xl font-bold text-base-content"><%= @members.count { |m| %w[admin manager super_admin].include?(m[:role]) } %></p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-1">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Agents</p>
        <p class="text-2xl font-bold text-base-content"><%= @members.count { |m| m[:role] == "agent" } %></p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-4 gap-1">
        <p class="text-xs text-base-content/50 uppercase tracking-wide font-medium">Active Members</p>
        <p class="text-2xl font-bold text-success"><%= @members.count { |m| m[:status] == "active" } %></p>
      </div>
    </div>
  </div>

  <%# Member Table %>
  <div class="card bg-base-100 border border-base-300">
    <div class="card-body p-5">
      <div class="flex items-center justify-between mb-4">
        <h2 class="font-medium text-base-content">Members</h2>
        <label class="input input-bordered input-sm flex items-center gap-2 w-64 bg-base-100">
          <%= icon "magnifying-glass", library: "heroicons", class: "size-4 text-base-content/40 shrink-0" %>
          <input type="text" placeholder="Search member..." class="grow bg-transparent outline-none text-sm" />
        </label>
      </div>

      <div class="overflow-x-auto">
        <table class="table table-sm w-full">
          <thead>
            <tr class="border-b border-base-200">
              <th class="text-xs text-base-content/40 font-medium">Member</th>
              <th class="text-xs text-base-content/40 font-medium">Role</th>
              <th class="text-xs text-base-content/40 font-medium text-center">Status</th>
              <th class="text-xs text-base-content/40 font-medium text-center">Leads</th>
              <th class="text-xs text-base-content/40 font-medium text-center">Activities</th>
              <th class="text-xs text-base-content/40 font-medium text-center">Won</th>
              <th class="text-xs text-base-content/40 font-medium">Joined</th>
              <th class="text-xs text-base-content/40 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% sorted_members.each do |member| %>
              <% rc = role_colors[member[:role]] || { badge: "badge-ghost", label: member[:role].capitalize } %>
              <tr class="border-b border-base-100 hover:bg-base-50 transition-colors">

                <%# Member Info %>
                <td class="py-3">
                  <div class="flex items-center gap-3">
                    <div class="avatar avatar-placeholder shrink-0">
                      <div class="bg-primary/10 text-primary rounded-full size-9">
                        <span class="text-sm font-bold"><%= member[:name].split.map(&:first).join.upcase[0..1] %></span>
                      </div>
                    </div>
                    <div>
                      <p class="text-sm font-medium text-base-content"><%= member[:name] %></p>
                      <p class="text-xs text-base-content/40"><%= member[:email] %></p>
                    </div>
                  </div>
                </td>

                <%# Role %>
                <td class="py-3">
                  <span class="badge badge-sm badge-outline <%= rc[:badge] %>"><%= rc[:label] %></span>
                </td>

                <%# Status %>
                <td class="py-3 text-center">
                  <span class="badge badge-sm badge-outline <%= member[:status] == 'active' ? 'badge-success' : 'badge-ghost' %>">
                    <%= member[:status].capitalize %>
                  </span>
                </td>

                <%# Stats %>
                <td class="py-3 text-center text-sm text-base-content/70"><%= member[:leads] %></td>
                <td class="py-3 text-center text-sm text-base-content/70"><%= member[:activities] %></td>
                <td class="py-3 text-center text-sm text-base-content/70"><%= member[:won] %></td>

                <%# Joined %>
                <td class="py-3 text-sm text-base-content/40"><%= member[:joined] %></td>

                <%# Actions %>
                <td class="py-3">
                  <div class="flex items-center justify-end gap-1">
                    <button class="btn btn-ghost btn-xs btn-circle" title="Edit role">
                      <%= icon "pencil", library: "heroicons", class: "size-4 text-base-content/50" %>
                    </button>
                    <button class="btn btn-ghost btn-xs btn-circle" title="Remove member">
                      <%= icon "trash", library: "heroicons", class: "size-4 text-error/60" %>
                    </button>
                  </div>
                </td>

              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# Role Legend %>
  <div class="card bg-base-100 border border-base-300 mt-3">
    <div class="card-body p-4">
      <p class="text-xs text-base-content/40 font-medium uppercase tracking-wide mb-3">Role Permissions</p>
      <div class="grid grid-cols-5 gap-3">
        <% [
          { role: "Super Admin", color: "badge-error",     desc: "Full access, billing, user management" },
          { role: "Admin",       color: "badge-primary",   desc: "Manage team, leads, all reports" },
          { role: "Manager",     color: "badge-secondary", desc: "View team data, manage assigned leads" },
          { role: "Agent",       color: "badge-success",   desc: "Manage own leads and activities" },
          { role: "Viewer",      color: "badge-ghost",     desc: "Read-only access to pipeline" },
        ].each do |r| %>
          <div class="flex flex-col gap-1.5">
            <span class="badge badge-sm badge-outline <%= r[:color] %>"><%= r[:role] %></span>
            <p class="text-xs text-base-content/50 leading-relaxed"><%= r[:desc] %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

</div>

<%# Invite Member Modal %>
<dialog id="invite_modal" class="modal">
  <div class="modal-box w-11/12 max-w-md">
    <div class="flex items-center justify-between mb-6">
      <h3 class="text-lg font-bold">Invite Member</h3>
      <button onclick="document.getElementById('invite_modal').close()" class="btn btn-ghost btn-sm btn-circle">
        <%= icon "x-mark", library: "heroicons", class: "size-5" %>
      </button>
    </div>

    <%= form_with url: dashboard_teams_path, method: :post, class: "space-y-4" do |f| %>

      <div class="form-control">
        <%= f.label :name, "Full Name *", class: "label label-text text-sm" %>
        <%= f.text_field :name, class: "input input-bordered w-full", required: true, placeholder: "e.g. Juan dela Cruz" %>
      </div>

      <div class="form-control">
        <%= f.label :email, "Email Address *", class: "label label-text text-sm" %>
        <%= f.email_field :email, class: "input input-bordered w-full", required: true, placeholder: "juan@trustline.com" %>
      </div>

      <div class="form-control">
        <%= f.label :role, "Role *", class: "label label-text text-sm" %>
        <%= f.select :role,
          [["Admin", "admin"], ["Manager", "manager"], ["Agent", "agent"], ["Viewer", "viewer"]],
          {},
          class: "select select-bordered w-full" %>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="document.getElementById('invite_modal').close()" class="btn btn-ghost btn-sm">
          Cancel
        </button>
        <%= f.submit "Send Invite", class: "btn btn-primary btn-sm" %>
      </div>

    <% end %>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
