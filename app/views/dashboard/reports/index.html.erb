<%# app/views/dashboard/reports/index.html.erb %>

<div class="p-6 bg-base-200 min-h-screen">

  <%# Header %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-bold text-base-content">Weekly Reports</h1>
      <p class="text-sm text-base-content/50 mt-0.5">Auto-generated weekly summaries</p>
    </div>
    <div class="flex gap-2">
      <%= link_to dashboard_reports_path(week_offset: @week_offset - 1),
            class: "cursor-pointer rounded-md border border-base-300 bg-base-100 px-4 py-2 text-sm text-base-content/60 hover:bg-base-200 transition flex items-center gap-2" do %>
        <%= icon "arrow-left", library: "heroicons", class: "size-4" %>
        Prev Week
      <% end %>

      <% unless @is_current %>
        <%= link_to dashboard_reports_path(week_offset: @week_offset + 1),
              class: "cursor-pointer rounded-md border border-base-300 bg-base-100 px-4 py-2 text-sm text-base-content/60 hover:bg-base-200 transition flex items-center gap-2" do %>
          Next Week
          <%= icon "arrow-right", library: "heroicons", class: "size-4" %>
        <% end %>
      <% end %>

      <%= link_to dashboard_reports_path(week_offset: @week_offset, format: :csv),
            class: "cursor-pointer rounded-md border border-base-300 bg-base-100 px-4 py-2 text-sm text-base-content/60 hover:bg-base-200 transition flex items-center gap-2" do %>
        <%= icon "arrow-down-tray", library: "heroicons", class: "size-4" %>
        CSV
      <% end %>

      <button onclick="window.print()"
              class="cursor-pointer rounded-md border border-base-300 bg-base-100 px-4 py-2 text-sm text-base-content/60 hover:bg-base-200 transition flex items-center gap-2">
        <%= icon "printer", library: "heroicons", class: "size-4" %>
        Print
      </button>
    </div>
  </div>

  <%# Week Banner %>
  <div class="card bg-base-100 border border-base-300 mb-5">
    <div class="card-body p-4 flex-row items-center gap-3">
      <p class="text-sm font-medium text-base-content">
        Week of <%= @week_start.strftime("%A, %B %-d") %> — <%= @week_end.strftime("%A, %B %-d, %Y") %>
      </p>
      <span class="text-xs text-base-content/40">Week <%= @week_number %></span>
      <% if @is_current %>
        <span class="badge badge-primary badge-sm">Current</span>
      <% end %>
      <% unless @week_offset == 0 %>
        <%= link_to "Back to current week →", dashboard_reports_path,
              class: "ml-auto text-xs text-primary hover:underline" %>
      <% end %>
    </div>
  </div>

  <%# KPI Cards %>
  <div class="grid grid-cols-4 gap-3 mb-5">
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-5 items-center text-center gap-1">
        <p class="text-3xl font-bold text-success"><%= @leads_added %></p>
        <p class="text-sm text-base-content/50">Leads Added</p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-5 items-center text-center gap-1">
        <p class="text-3xl font-bold text-error"><%= @leads_removed %></p>
        <p class="text-sm text-base-content/50">Leads Removed</p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-5 items-center text-center gap-1">
        <p class="text-3xl font-bold <%= @net_growth >= 0 ? 'text-success' : 'text-error' %>">
          <%= @net_growth >= 0 ? "+#{@net_growth}" : @net_growth %>
        </p>
        <p class="text-sm text-base-content/50">Net Growth</p>
      </div>
    </div>
    <div class="card bg-base-100 border border-base-300">
      <div class="card-body p-5 items-center text-center gap-1">
        <p class="text-3xl font-bold text-primary"><%= @moved_forward %></p>
        <p class="text-sm text-base-content/50">Moved Forward</p>
      </div>
    </div>
  </div>

  <%# Team Summary + Alerts Row %>
  <div class="grid grid-cols-3 gap-3 mb-5">

    <%# Team Summary %>
    <div class="card bg-base-100 border border-base-300 col-span-2">
      <div class="card-body p-5">
        <h2 class="font-medium text-base-content mb-4">Team Summary</h2>
        <% if @team_summary.empty? %>
          <div class="overflow-x-auto">
            <table class="table table-sm w-full">
              <thead>
                <tr class="border-b border-base-200">
                  <th class="text-xs text-base-content/40 font-medium">Agent</th>
                  <th class="text-xs text-base-content/40 font-medium text-center">Added</th>
                  <th class="text-xs text-base-content/40 font-medium text-center">Removed</th>
                  <th class="text-xs text-base-content/40 font-medium text-center">Moved</th>
                  <th class="text-xs text-base-content/40 font-medium text-center">Activities</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td colspan="5" class="py-10 text-center text-sm text-base-content/30">No data this week</td>
                </tr>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="overflow-x-auto">
            <table class="table table-sm w-full">
              <thead>
                <tr class="border-b border-base-200">
                  <th class="text-xs text-base-content/40 font-medium">Agent</th>
                  <th class="text-xs text-base-content/40 font-medium text-center">Added</th>
                  <th class="text-xs text-base-content/40 font-medium text-center">Removed</th>
                  <th class="text-xs text-base-content/40 font-medium text-center">Moved</th>
                  <th class="text-xs text-base-content/40 font-medium text-center">Activities</th>
                </tr>
              </thead>
              <tbody>
                <% @team_summary.each do |s| %>
                  <tr class="border-b border-base-100 hover:bg-base-50">
                    <td>
                      <div class="flex items-center gap-2">
                        <div class="avatar avatar-placeholder">
                          <div class="bg-primary/10 text-primary rounded-full size-7">
                            <span class="text-xs font-bold"><%= s[:user].initials %></span>
                          </div>
                        </div>
                        <span class="text-sm font-medium text-base-content"><%= s[:user].display_name %></span>
                      </div>
                    </td>
                    <td class="text-center text-sm text-success font-medium">+<%= s[:added] %></td>
                    <td class="text-center text-sm text-error font-medium">-<%= s[:removed] %></td>
                    <td class="text-center text-sm text-base-content/70"><%= s[:moved] %></td>
                    <td class="text-center text-sm text-base-content/70"><%= s[:activities] %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>

    <%# Right column %>
    <div class="flex flex-col gap-3">

      <%# Removals by Reason %>
      <div class="card bg-base-100 border border-base-300">
        <div class="card-body p-5">
          <h2 class="font-medium text-base-content mb-3">Removals by Reason</h2>
          <% if @removals_by_reason.empty? %>
            <p class="text-sm text-base-content/30">No removals this week</p>
          <% else %>
            <div class="space-y-0 divide-y divide-base-200">
              <% @removals_by_reason.each do |r| %>
                <div class="flex items-center justify-between py-2">
                  <span class="text-sm text-base-content/70"><%= r[:reason] %></span>
                  <span class="text-sm font-bold text-error"><%= r[:count] %></span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <%# Alerts %>
      <div class="card bg-base-100 border border-base-300">
        <div class="card-body p-5">
          <h2 class="font-medium text-base-content mb-3">Alerts</h2>
          <div class="space-y-0 divide-y divide-base-200">
            <div class="flex items-center justify-between py-2.5">
              <span class="text-sm text-base-content/70">Overdue Actions</span>
              <span class="text-sm font-bold <%= @overdue_count > 0 ? 'text-error' : 'text-base-content/40' %>">
                <%= @overdue_count %>
              </span>
            </div>
            <div class="flex items-center justify-between py-2.5">
              <span class="text-sm text-base-content/70">Stagnant (7+ days)</span>
              <span class="text-sm font-bold <%= @stagnant_count > 0 ? 'text-warning' : 'text-base-content/40' %>">
                <%= @stagnant_count %>
              </span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <%# Leads Added This Week %>
  <div class="card bg-base-100 border border-base-300 mb-3">
    <div class="card-body p-5">
      <h2 class="font-medium text-base-content mb-4">
        Leads Added This Week (<%= @leads_added %>)
      </h2>
      <% if @leads_added_list.empty? %>
        <p class="text-sm text-base-content/30 text-center py-4">None added</p>
      <% else %>
        <div class="overflow-x-auto">
          <table class="table table-sm w-full">
            <thead>
              <tr class="border-b border-base-200">
                <th class="text-xs text-base-content/40 font-medium">Company</th>
                <th class="text-xs text-base-content/40 font-medium">Contact</th>
                <th class="text-xs text-base-content/40 font-medium">Stage</th>
                <th class="text-xs text-base-content/40 font-medium">Source</th>
                <th class="text-xs text-base-content/40 font-medium">Owner</th>
                <th class="text-xs text-base-content/40 font-medium">Date Added</th>
              </tr>
            </thead>
            <tbody>
              <% @leads_added_list.each do |lead| %>
                <tr class="border-b border-base-100 hover:bg-base-50">
                  <td>
                    <%= link_to lead.company_name,
                          dashboard_lead_path(lead),
                          class: "text-sm font-medium text-base-content hover:text-primary" %>
                  </td>
                  <td class="text-sm text-base-content/60"><%= lead.contact_name %></td>
                  <td>
                    <span class="badge badge-ghost badge-sm"><%= lead.stage.humanize.gsub("_", " ") %></span>
                  </td>
                  <td class="text-sm text-base-content/60"><%= lead.source.humanize %></td>
                  <td class="text-sm text-base-content/60"><%= lead.owner&.display_name %></td>
                  <td class="text-sm text-base-content/60"><%= lead.date_added&.strftime("%b %-d, %Y") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>

  <%# Leads Removed This Week %>
  <div class="card bg-base-100 border border-base-300">
    <div class="card-body p-5">
      <h2 class="font-medium text-base-content mb-4">
        Leads Removed This Week (<%= @leads_removed %>)
      </h2>
      <% if @leads_removed_list.empty? %>
        <p class="text-sm text-base-content/30 text-center py-4">None removed</p>
      <% else %>
        <div class="overflow-x-auto">
          <table class="table table-sm w-full">
            <thead>
              <tr class="border-b border-base-200">
                <th class="text-xs text-base-content/40 font-medium">Company</th>
                <th class="text-xs text-base-content/40 font-medium">Contact</th>
                <th class="text-xs text-base-content/40 font-medium">Reason</th>
                <th class="text-xs text-base-content/40 font-medium">Removed By</th>
                <th class="text-xs text-base-content/40 font-medium">Date Removed</th>
              </tr>
            </thead>
            <tbody>
              <% @leads_removed_list.each do |lead| %>
                <tr class="border-b border-base-100 hover:bg-base-50">
                  <td>
                    <%= link_to lead.company_name,
                          dashboard_lead_path(lead),
                          class: "text-sm font-medium text-base-content hover:text-primary" %>
                  </td>
                  <td class="text-sm text-base-content/60"><%= lead.contact_name %></td>
                  <td>
                    <span class="badge badge-error badge-soft badge-sm">
                      <%= lead.removal_reason.presence || "Not specified" %>
                    </span>
                  </td>
                  <td class="text-sm text-base-content/60"><%= lead.last_updated_by&.display_name || "—" %></td>
                  <td class="text-sm text-base-content/60"><%= lead.date_removed&.strftime("%b %-d, %Y") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </div>
  </div>

</div>
